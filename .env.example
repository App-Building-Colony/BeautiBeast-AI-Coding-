# Agent-Sentinel – Agnostic Provider Proxy
# Copy to .env.local

# --- Agnostic LLM Keys (rotate per workspace) ---
OPENROUTER_API_KEY=sk-or-v1-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# Default swarm model routing
AGENT_DEFAULT_PROVIDER=openrouter
AGENT_DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# Ollama local
OLLAMA_BASE_URL=http://localhost:11434

# --- GitHub ---
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=whsec_...

# Auto-merge gatekeeper
AUTO_MERGE_ENABLED=false

# Manual Override JWT
OVERRIDE_JWT_SECRET=change_me_32+chars

# Vercel
NEXT_PUBLIC_APP_URL=https://agent-sentinel.vercel.app
